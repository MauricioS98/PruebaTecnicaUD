# Copia a .env en backend/ para docker compose: cp .env.docker.example .env
# GOOGLE_CLIENT_ID es obligatorio para arrancar la API.

JWT_SECRET=change_me_in_production_use_long_random_secret
JWT_EXPIRES_IN=8h
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
CORS_ORIGIN=http://localhost:4200
