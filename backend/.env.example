PORT=3000
NODE_ENV=production

# --- Opción recomendada en Render + Aiven ---
# Pega la Service URI completa desde Aiven (incluye sslmode=require)
DATABASE_URL=postgres://avnadmin:PASSWORD@HOST.aivencloud.com:PORT/defaultdb?sslmode=require

# --- O variables separadas ---
# DB_HOST=HOST.aivencloud.com
# DB_PORT=PORT
# DB_NAME=defaultdb
# DB_USER=avnadmin
# DB_PASSWORD=PASSWORD

# Obligatorio para Postgres en la nube
DB_SSL=true
PGSSLMODE=require

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# URL de tu frontend en Vercel
CORS_ORIGIN=https://tu-app.vercel.app
